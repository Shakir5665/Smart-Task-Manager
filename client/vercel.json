{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "env": {
    "VITE_API_URL": "https://your-backend.onrender.com"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },

  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ]

}
